{
  "name": "groovy-drummer",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "predev": "npm run generate:catalog && npm run verify-home-kit",
    "dev": "vite --host 0.0.0.0",
    "prepare:home-kit": "node scripts/prepare-home-kit.mjs",
    "verify-home-kit": "node scripts/verify-home-kit.mjs",
    "validate:home-kit-mix": "node scripts/validate-home-kit-mix.mjs",
    "validate:groovy-drummer": "node scripts/validate-groovy-drummer.mjs",
    "generate:catalog": "node scripts/generate-catalog.mjs",
    "build": "npm run generate:catalog && npm run verify-home-kit && npm run validate:groovy-drummer && npm run validate:home-kit-mix && tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "jszip": "^3.10.1",
    "lucide": "^0.468.0",
    "tone": "^14.7.77"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
